# Copia este archivo a ".env" y rellena tu clave.
#
#   cp .env.example .env
#
# Si dejas las claves vacias, la app funciona igual en MODO DEMO
# (devuelve macros simulados). Configura una para usar IA real.

# --- Opcion A: OpenRouter (recomendado) ---
# Registrate en https://openrouter.ai/keys, crea una key y ponla aqui.
# Tiene modelos gratis como google/gemini-2.5-flash:free (>1000 usos/dia)
AI_PROVIDER=openrouter
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-2.5-flash:free

# --- Opcion B: Google Gemini ---
# Alternativa: https://aistudio.google.com/apikey (limite ~20/dia gratis)
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.5-flash

# Puerto del servidor local
PORT=3000
