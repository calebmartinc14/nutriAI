# Copia este archivo a ".env" y rellena tu clave.
#
#   cp .env.example .env
#
# Si dejas GEMINI_API_KEY vacio, la app funciona igual en MODO DEMO
# (devuelve macros simulados). Mete la clave para usar IA real.

# Clave de Google Gemini (https://aistudio.google.com/apikey)
GEMINI_API_KEY=

# Modelo de vision/chat a usar
GEMINI_MODEL=gemini-1.5-flash

# Puerto del servidor local
PORT=3000
