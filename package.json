{
  "name": "nutveo-web",
  "version": "0.1.0",
  "description": "Nutveo — Tracker de macros y calorías con IA",
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "dev": "concurrently -k -n api,vite -c blue,green \"node --watch server.js\" \"vite\"",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint src server.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0"
  },
  "devDependencies": {
    "concurrently": "^10.0.3",
    "eslint": "^9.26.0",
    "globals": "^17.7.0",
    "vite": "^8.1.3",
    "vitest": "^4.1.9"
  }
}
